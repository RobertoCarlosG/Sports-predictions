# PostgreSQL (Supabase or local). Use asyncpg driver.
# Si Render/Supabase te dan postgresql:// sin +asyncpg, el backend lo corrige al arrancar.
# Tras PgBouncer: URL con prepared_statement_cache_size=0, asyncpg sin caché de statements,
# nombres únicos, y NullPool (sin pool en el proceso; el pool lo hace PgBouncer). Ver db/session.py.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sports_predictions

# CORS: comma-separated origins (incluye tu dominio Vercel exacto, sin barra final)
CORS_ORIGINS=http://localhost:4200,https://tu-app.vercel.app

# DEBUG=true incluye campo "technical" en JSON de errores (no usar en prod pública)
DEBUG=false

# Optional: override MLB API base (default: https://statsapi.mlb.com/api/v1)
# MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1
