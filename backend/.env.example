# PostgreSQL (Supabase or local). Use asyncpg driver.
# Si Render/Supabase te dan postgresql:// sin +asyncpg, el backend lo corrige al arrancar.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sports_predictions
# Tiempo máximo por sentencia SQL (0 = usar default del servidor).
# Con optimizaciones de código (upsert_team), 300s (5 min) es suficiente.
# DATABASE_STATEMENT_TIMEOUT_SECONDS=300

# CORS: comma-separated origins (incluye tu dominio Vercel exacto, sin barra final)
CORS_ORIGINS=http://localhost:4200,https://tu-app.vercel.app

# DEBUG=true incluye campo "technical" en JSON de errores (no usar en prod pública)
DEBUG=false

# Modelo entrenado (joblib). Vacío = `src/app/ml/artifacts/model.joblib` relativo al cwd del proceso.
# Tras `python -m app.ml.train_from_db`, apunta aquí al archivo generado o cópialo como model.joblib.
# ML_MODEL_PATH=

# Optional: override MLB API base (default: https://statsapi.mlb.com/api/v1)
# MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1
# Ráfaga MLB: tras N peticiones HTTP a statsapi, pausa (compartido por todo el proceso). 0 = sin límite.
# MLB_API_RATE_LIMIT_BURST_SIZE=5
# MLB_API_RATE_LIMIT_COOLDOWN_SECONDS=25

# --- Pipeline / ML (por defecto el arranque es manual: sin precálculo ni modelo sintético)
# Si true, al arrancar sin joblib válido se crea un modelo sintético en memoria (solo desarrollo).
# ML_AUTO_SYNTHETIC_ON_MISSING=false
# Si true, tras sync se dispara precálculo de prediction_results en segundo plano.
# PIPELINE_AUTO_CACHE_PREDICTIONS=false

# --- Panel de operaciones (JWT en cookie HttpOnly para /api/v1/admin/*)
# Secreto fuerte en producción. Sin esto, login admin falla.
# ADMIN_JWT_SECRET=cambia-esto-en-produccion
# Duración del JWT del panel (minutos). Por defecto en código: 240. Importaciones largas: 480–720 o usa el
# renovado automático del front durante el backfill (POST /admin/auth/refresh cada ~90 s).
# ADMIN_TOKEN_EXPIRE_MINUTES=480
#
# Primer usuario (solo si admin_users está vacío): POST /api/v1/admin/auth/bootstrap
# con header X-Admin-Bootstrap-Secret igual a este valor. Luego borra la variable del entorno.
# ADMIN_BOOTSTRAP_SECRET=
# Cookie: nombre, SameSite (lax|strict|none), Secure, dominio opcional.
# Front y API en dominios distintos: ADMIN_COOKIE_SAMESITE=none y ADMIN_COOKIE_SECURE=true
# ADMIN_COOKIE_NAME=sp_admin_access
# ADMIN_COOKIE_SAMESITE=lax
# ADMIN_COOKIE_SECURE=false
# ADMIN_COOKIE_DOMAIN=
